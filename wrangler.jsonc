{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "sp500-sector-heatmap-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-07-03",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
