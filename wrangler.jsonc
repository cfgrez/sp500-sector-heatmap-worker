{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "sp500-sector-heatmap",
  "main": "src/index.js",
  "compatibility_date": "2026-07-02",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
